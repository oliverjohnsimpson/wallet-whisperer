# Server port
PORT=8787

# Allowed origin for CORS (your web app's dev/prod URL)
WEB_ORIGIN=http://localhost:5173

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-side ONLY, never expose to the frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Razorpay — https://dashboard.razorpay.com (Settings → API Keys, and Subscriptions → Plans)
# Leave blank to keep the app running with upgrades disabled.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Plan IDs created in the Razorpay dashboard (monthly ₹199 and ₹499 plans)
RAZORPAY_PLAN_STANDARD=plan_xxxxxxxx
RAZORPAY_PLAN_PROFESSIONAL=plan_xxxxxxxx
